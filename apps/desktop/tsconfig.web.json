{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "out",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/App.tsx", "src/main.tsx", "src/env.d.ts", "src/index.css", "src/screens/**/*"]
}
